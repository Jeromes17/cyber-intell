{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentTelemetryBatch",
  "type": "object",
  "required": ["agent_id", "records"],
  "properties": {
    "agent_id": { "type": "string", "minLength": 1 },
    "agent_version": { "type": "string" },
    "ts": { "type": "string", "format": "date-time" },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ts",
          "process_name",
          "cpu_percent",
          "mem_percent",
          "net_bytes_sent_per_s",
          "net_bytes_recv_per_s",
          "num_child_processes"
        ],
        "properties": {
          "ts": { "type": "string", "format": "date-time" },
          "client_record_id": { "type": "string" },
          "process_name": { "type": "string" },
          "parent_process": { "type": "string" },

          "cpu_percent": { "type": "number", "minimum": 0 },
          "mem_percent": { "type": "number", "minimum": 0 },

          "net_bytes_sent_per_s": { "type": "number", "minimum": 0 },
          "net_bytes_recv_per_s": { "type": "number", "minimum": 0 },

          "num_child_processes": { "type": "integer", "minimum": 0 },
          "process_start_age_seconds": { "type": "number", "minimum": 0 },

          "connections": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ip", "port"],
              "properties": {
                "ip": { "type": "string", "minLength": 7 },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
